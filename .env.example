# Skopiuj do .env i uzupełnij wartości.
ELEVENLABS_API_KEY=

# Opcjonalne — głos i model:
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Opcjonalne — ustawienia głosu (suwaki na stronie ElevenLabs):
# ELEVENLABS_STABILITY=0.5       # Stability (0.0–1.0)
# ELEVENLABS_SIMILARITY=0.75     # Similarity (0.0–1.0)
# ELEVENLABS_STYLE=0.0           # Style exaggeration (0.0–1.0)
# ELEVENLABS_SPEAKER_BOOST=true  # Speaker boost (true/false)
# ELEVENLABS_SPEED=1.0           # Speed (0.7–1.2)
